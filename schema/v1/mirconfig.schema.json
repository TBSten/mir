{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/tbsten/mir/blob/main/schema/v1/mirconfig.schema.json",
  "title": "mir global configuration",
  "description": "mir の設定ファイル（~/.mir/config.yaml または .mir/config.yaml）のスキーマ",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "registries": {
      "type": "array",
      "description": "registry の一覧。定義順に検索される",
      "items": {
        "$ref": "#/$defs/registryEntry"
      },
      "default": [
        { "path": "~/.mir/registry" }
      ]
    },
    "locale": {
      "type": "string",
      "description": "CLI の表示言語",
      "enum": ["ja", "en"],
      "default": "ja"
    },
    "defaults": {
      "type": "object",
      "description": "snippet 作成時のデフォルト値",
      "additionalProperties": false,
      "properties": {
        "author": {
          "type": "string",
          "description": "snippet 作成時のデフォルト author"
        }
      }
    }
  },
  "$defs": {
    "registryEntry": {
      "type": "object",
      "description": "registry の定義。path（ローカル）または url（リモート）のいずれかを指定する",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "registry の識別名。--registry オプションで指定する際に使用"
        },
        "path": {
          "type": "string",
          "description": "ローカル registry のディレクトリパス。url と排他"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "リモート registry の URL。path と排他。読み取り専用",
          "pattern": "^https?://"
        }
      },
      "oneOf": [
        {
          "required": ["path"],
          "not": { "required": ["url"] }
        },
        {
          "required": ["url"],
          "not": { "required": ["path"] }
        }
      ]
    }
  }
}
