exports[`snippet スキーマ snapshot > hooks 付き snippet 定義の YAML 出力 1`] = `
"name: with-hooks
hooks:
  before-install:
    - echo: インストールを開始します
    - input:
        confirm:
          description: 続行しますか？
          answer-to: confirmed
          schema:
            type: boolean
            default: true
  after-install:
    - echo: ✅ インストール完了
"
`;

