{
  "name": "@tbsten/mir-core",
  "version": "0.0.2-alpha08",
  "description": "スニペット配布・取得ツール mir のコアロジック（テンプレート、スキーマ、i18n）",
  "type": "module",
  "keywords": [
    "snippet",
    "template",
    "handlebars",
    "scaffold",
    "generator"
  ],
  "author": "tbsten",
  "license": "MIT",
  "homepage": "https://mir.tbsten.me",
  "repository": {
    "type": "git",
    "url": "https://github.com/tbsten/mir.git",
    "directory": "packages/mir-core"
  },
  "bugs": {
    "url": "https://github.com/tbsten/mir/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.1"
  },
  "scripts": {
    "generate:validators": "tsx scripts/generate-validators.ts",
    "prebuild": "npm run generate:validators",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4"
  }
}
