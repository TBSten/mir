{
  "name": "@mir/official-registry",
  "version": "0.0.2-alpha06",
  "description": "mir 公式 Registry（HonoX + Cloudflare Pages）",
  "private": true,
  "type": "module",
  "author": "tbsten",
  "license": "MIT",
  "homepage": "https://mir.tbsten.me",
  "repository": {
    "type": "git",
    "url": "https://github.com/tbsten/mir.git",
    "directory": "packages/official-registry"
  },
  "bugs": {
    "url": "https://github.com/tbsten/mir/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tailwindcss -i app/styles.css -o dist/static/styles.css --minify && vite build",
    "deploy": "wrangler pages deploy dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:vrt": "playwright test --grep @vrt"
  },
  "dependencies": {
    "@tbsten/mir-registry-sdk": "*",
    "hono": "^4.12.5",
    "honox": "^0.1.54"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@hono/vite-build": "^1.10.0",
    "@hono/vite-dev-server": "^0.25.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^4",
    "wrangler": "^4.70.0"
  }
}
