{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "noEmit": true,
    "types": ["vite/client", "@cloudflare/workers-types"]
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
