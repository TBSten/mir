// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`snippet YAML シリアライズ snapshot > hooks 付き snippet 定義 1`] = `
"# yaml-language-server: $schema=https://raw.githubusercontent.com/TBSten/mir/refs/heads/main/schema/v1/snippet.schema.json
name: with-hooks
variables:
  name:
    schema:
      type: string
hooks:
  before-install:
    - echo: Installing {{ name }}...
    - exit: true
      if: '{{ skipInstall }}'
  after-install:
    - echo: Done! Created {{ name }}
"
`;

exports[`snippet YAML シリアライズ snapshot > 全フィールドを含む snippet 定義 1`] = `
"# yaml-language-server: $schema=https://raw.githubusercontent.com/TBSten/mir/refs/heads/main/schema/v1/snippet.schema.json
name: full-example
description: 全フィールドを含む例
variables:
  name:
    name: コンポーネント名
    description: 生成するコンポーネントの名前
    suggests:
      - Button
      - Input
      - Modal
    schema:
      type: string
  useTs:
    description: TypeScript を使用するか
    suggests:
      - 'true'
      - 'false'
    schema:
      type: boolean
      default: true
hooks:
  before-install:
    - echo: Creating {{ name }}...
    - input:
        confirm-ts:
          name: TypeScript
          description: TypeScript を使いますか？
          schema:
            type: boolean
            default: true
          answer-to: useTs
  after-install:
    - echo: '{{ name }} was created successfully!'
"
`;

exports[`snippet YAML シリアライズ snapshot > 変数付き snippet 定義 1`] = `
"# yaml-language-server: $schema=https://raw.githubusercontent.com/TBSten/mir/refs/heads/main/schema/v1/snippet.schema.json
name: with-vars
description: テスト用 snippet
variables:
  name:
    description: コンポーネント名
    schema:
      type: string
  count:
    schema:
      type: number
      default: 3
  framework:
    suggests:
      - react
      - vue
      - svelte
    schema:
      type: string
      default: react
"
`;

exports[`snippet YAML シリアライズ snapshot > 最小の snippet 定義 1`] = `
"# yaml-language-server: $schema=https://raw.githubusercontent.com/TBSten/mir/refs/heads/main/schema/v1/snippet.schema.json
name: minimal
"
`;
