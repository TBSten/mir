exports[`エラーメッセージ snapshot (英語) > FileConflictError 1`] = `"File "index.ts" already exists. Use \`--no-interactive\` to overwrite all files or \`--out-dir\` to specify another directory"`;

exports[`エラーメッセージ snapshot (英語) > PathTraversalError 1`] = `"Security error: File path "../secret.txt" references outside the output directory. Check your template files"`;

exports[`エラーメッセージ snapshot (英語) > RegistryNotFoundError 1`] = `"Registry "team" not found. Configure registries in \`~/.mir/mirconfig.yaml\`"`;

