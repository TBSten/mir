{
  "name": "mir",
  "version": "0.0.1",
  "description": "スニペット(ディレクトリ構造含む)を配布・取得するCLIツール",
  "type": "module",
  "bin": {
    "mir": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "snippet",
    "scaffold",
    "template"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  }
}
