{
  "name": "@tbsten/mir",
  "version": "0.0.1-alpha03",
  "description": "スニペット(ディレクトリ構造含む)を配布・取得するCLIツール",
  "type": "module",
  "bin": {
    "mir": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "snippet",
    "scaffold",
    "template"
  ],
  "author": "tbsten",
  "license": "MIT",
  "homepage": "https://mir.tbsten.me",
  "repository": {
    "type": "git",
    "url": "https://github.com/tbsten/mir.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/tbsten/mir/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "fast-check": "^4.5.3",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  },
  "dependencies": {
    "@tbsten/mir-core": "*",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.1"
  }
}
